generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 用户 ───────────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  skills    Skill[]
}

// ─── 项目 ───────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  created
  spec_generating
  code_generating
  reviewing
  building
  fixing
  running
  failed
  stopped
}

model Project {
  id             String        @id @default(uuid())
  userId         String
  title          String        @default("Untitled")
  originalPrompt String
  specJson       Json?
  status         ProjectStatus @default(created)
  sandboxId      String?
  previewUrl     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user                 User                  @relation(fields: [userId], references: [id])
  messages             Message[]
  files                ProjectFile[]
  buildLogs            BuildLog[]
  agentRuns            AgentRun[]
  runs                 ProjectRun[]
  sandboxSession       SandboxSession?
  agentConversation    AgentConversation?
  skills               Skill[]
  conversationHistory  ConversationHistory[]
  compressionSummaries CompressionSummary[]

  @@index([userId])
}

// ─── 聊天消息 ────────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
  system
}

model Message {
  id        String      @id @default(uuid())
  projectId String
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── 项目文件快照 ─────────────────────────────────────────────────────────────────

model ProjectFile {
  id         String   @id @default(uuid())
  projectId  String
  path       String
  content    String
  size       Int?
  version    Int      @default(1)
  syncSource String   @default("periodic")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([projectId])
  @@index([projectId, updatedAt])
}

// ─── 构建日志 ────────────────────────────────────────────────────────────────────

model BuildLog {
  id        String   @id @default(uuid())
  projectId String
  runId     String?
  command   String
  stdout    String   @default("")
  stderr    String   @default("")
  exitCode  Int?
  diagnosis String?
  attempt   Int      @default(1)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([runId])
}

// ─── Project Run（执行生命周期） ──────────────────────────────────────────────────

enum ProjectRunType {
  generate
  iterate
}

enum ProjectRunStatus {
  queued
  running
  waiting_for_user
  paused
  cancelling
  cancelled
  succeeded
  failed
}

model ProjectRun {
  id              String           @id @default(uuid())
  projectId       String
  userId          String
  type            ProjectRunType
  status          ProjectRunStatus @default(queued)
  prompt          String
  error           String?
  sandboxId       String?
  previewUrl      String?
  currentAskCount Int?             @default(0)
  pausedAt        DateTime?
  pauseReason     String?
  startedAt       DateTime?
  finishedAt      DateTime?
  heartbeatAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([projectId, status])
}

// ─── Agent 运行记录（旧版，保留兼容） ────────────────────────────────────────────────

enum AgentRunType {
  spec
  codegen
  review
  fix
}

enum AgentRunStatus {
  running
  completed
  failed
}

model AgentRun {
  id           String         @id @default(uuid())
  projectId    String
  type         AgentRunType
  inputSummary String?
  outputJson   Json?
  status       AgentRunStatus @default(running)
  createdAt    DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Sandbox 会话 ────────────────────────────────────────────────────────────────

enum SandboxStatus {
  creating
  running
  stopped
  expired
}

model SandboxSession {
  id         String        @id @default(uuid())
  projectId  String        @unique
  sandboxId  String
  provider   String        @default("e2b")
  status     SandboxStatus @default(creating)
  previewUrl String?
  startedAt  DateTime      @default(now())
  stoppedAt  DateTime?
  expiresAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Agent 对话记忆 ──────────────────────────────────────────────────────────────

model AgentConversation {
  id            String   @id @default(uuid())
  projectId     String   @unique
  userId        String
  sandboxId     String?
  messages      Json     @default("[]")
  summary       String?
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── 上下文管理 v2：全量历史落盘 ─────────────────────────────────────────────────────

model ConversationHistory {
  id         String   @id @default(uuid())
  projectId  String
  runId      String
  messages   Json
  startStep  Int
  endStep    Int
  tokenCount Int
  isFinal    Boolean  @default(false)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, runId])
  @@index([projectId, startStep])
}

model CompressionSummary {
  id              String   @id @default(uuid())
  projectId       String
  runId           String
  summary         String
  summaryTokens   Int
  coversStepStart Int
  coversStepEnd   Int
  version         Int
  modelUsed       String?
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, version])
  @@index([projectId, runId])
}

// ─── Agent Loop 挂起状态（ask_user 时保存） ──────────────────────────────────────

model LoopState {
  id           String   @id @default(uuid())
  runId        String   @unique
  messages     Json
  step         Int
  state        Json
  answerToken  String   @unique
  createdAt    DateTime @default(now())
}

// ─── Skill 系统 ─────────────────────────────────────────────────────────────────

enum SkillType {
  builtin
  composite
  mcp
}

enum SkillScope {
  global
  user
  project
}

model Skill {
  id             String     @id @default(cuid())
  name           String
  displayName    String
  description    String
  category       String
  schema         Json
  type           SkillType
  implementation Json?
  mcpConfig      Json?
  scope          SkillScope
  userId         String?
  projectId      String?
  version        Int        @default(1)
  enabled        Boolean    @default(true)
  usageCount     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user    User?    @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([name, scope, userId, projectId])
  @@index([userId, scope])
  @@index([projectId, scope])
}
