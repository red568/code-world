# ─── 数据库（Railway PostgreSQL，从 Railway 控制台获取连接地址） ─────────────────
DATABASE_URL="postgresql://postgres:xxx@xxx.railway.app:5432/railway"

# ─── Redis（Railway Redis，从 Railway 控制台获取连接地址） ────────────────────────
REDIS_URL="redis://default:xxx@xxx.railway.app:6379"

# ─── E2B ────────────────────────────────────────────────────────────────────────
E2B_API_KEY="your-e2b-api-key"
E2B_TEMPLATE_ID="vite-react-tailwind"

# ─── LLM (默认使用 DeepSeek V4 Flash，兼容 OpenAI 接口) ─────────────────────────
# Provider: deepseek | openai | anthropic | kimi
LLM_PROVIDER="deepseek"
LLM_API_KEY="your-deepseek-api-key"
LLM_BASE_URL="https://api.deepseek.com/v1"
# 模型切换：deepseek-v4-flash (快+便宜) | deepseek-v4-pro (质量更高)
LLM_MODEL="deepseek-v4-flash"

# ─── v7 沙盒架构 ──────────────────────────────────────────────────────────────
# 设为 true 启用新架构（Agent Loop 在沙盒内运行），false 使用旧架构
USE_SANDBOX_RUNTIME="false"
# 沙盒模板名称
E2B_TEMPLATE="ai-website-builder-v2"
# 内部 API 认证密钥（沙盒 → 后端通信）
INTERNAL_API_SECRET="your-internal-api-secret"
# 后端 API 地址（沙盒内访问）
API_BASE_URL="http://localhost:3000"

# ─── 可选：Axiom 日志 ─────────────────────────────────────────────────────────
AXIOM_TOKEN=""

# ─── 应用配置 ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
